# ── Backup files ─────────────────────────────────────────────────────────────
*.bak
*.bak-*
*.bak.*
admin.bak/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo

# ── Runtime / application data (never version-controlled) ────────────────────
data/
*.log
logs/

