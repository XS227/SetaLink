# ── Backup files ─────────────────────────────────────────────────────────────
*.bak
*.bak-*
*.bak.*
admin.bak/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo

# ── Runtime / application data (never version-controlled) ────────────────────
data/
*.log
logs/

# ── APK files — tracked via Git LFS (see .gitattributes) ─────────────────────
# Build outputs are ignored by mobile-app/.gitignore (android/app/build/).
# Release APKs in public/releases/ are committed through LFS.
# The download symlink (setalink-latest.apk) is tracked as a regular symlink.
public/assets/*.apk

# ── Android build artifacts ───────────────────────────────────────────────────
mobile-app/android/app/.cxx/
mobile-app/android/app/build/
mobile-app/android/build/
mobile-app/android/.gradle/
mobile-app/android/local.properties

# ── Node / JS tooling ─────────────────────────────────────────────────────────
mobile-app/node_modules/
mobile-app/.metro-cache/
mobile-app/*.jsbundle

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
mobile-app/.env
mobile-app/.env.*
