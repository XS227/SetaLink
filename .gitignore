*.apk
public/releases/
public/assets/*.apk

# ── Android build artifacts ───────────────────────────────────────────────────
mobile-app/android/app/.cxx/
mobile-app/android/app/build/
mobile-app/android/build/
mobile-app/android/.gradle/
mobile-app/android/local.properties

# ── Node / JS tooling ─────────────────────────────────────────────────────────
mobile-app/node_modules/
mobile-app/.metro-cache/
mobile-app/*.jsbundle

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
mobile-app/.env
mobile-app/.env.*
