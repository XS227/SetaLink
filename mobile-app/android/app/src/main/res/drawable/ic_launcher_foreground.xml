<?xml version="1.0" encoding="utf-8"?>
<!--
  SetaLink launcher — stylized lion/sun emblem in gold.
  Canvas: 108dp adaptive icon. Safe zone: 18–90dp.
  Sun body: circle at center. 8 pointed rays radiating outward.
  Mane ring: concentric arc strokes around the sun body.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 8 sun rays — diamond/rhombus shapes radiating at 45° increments -->
    <!-- Top -->
    <path android:fillColor="#D4AF37"
        android:pathData="M54,18 L57,36 L54,40 L51,36 Z" />
    <!-- Top-right -->
    <path android:fillColor="#D4AF37"
        android:pathData="M76.4,31.6 L68,46 L63.5,44 L68,31.6 Z" />
    <!-- Right -->
    <path android:fillColor="#D4AF37"
        android:pathData="M90,54 L72,57 L68,54 L72,51 Z" />
    <!-- Bottom-right -->
    <path android:fillColor="#D4AF37"
        android:pathData="M76.4,76.4 L63.5,64 L64,59.5 L78,68 Z" />
    <!-- Bottom -->
    <path android:fillColor="#D4AF37"
        android:pathData="M54,90 L51,72 L54,68 L57,72 Z" />
    <!-- Bottom-left -->
    <path android:fillColor="#D4AF37"
        android:pathData="M31.6,76.4 L44,63.5 L48.5,64 L40,78 Z" />
    <!-- Left -->
    <path android:fillColor="#D4AF37"
        android:pathData="M18,54 L36,51 L40,54 L36,57 Z" />
    <!-- Top-left -->
    <path android:fillColor="#D4AF37"
        android:pathData="M31.6,31.6 L40,44 L44.5,44 L40,30 Z" />

    <!-- Outer mane ring (suggests lion's mane) -->
    <path android:fillColor="#C9982A"
        android:pathData="M54,28 A26,26,0,1,1,53.99,28 Z" />

    <!-- Inner sun circle (bright gold) -->
    <path android:fillColor="#F0D060"
        android:pathData="M54,35 A19,19,0,1,1,53.99,35 Z" />

    <!-- S lettermark in dark over the sun -->
    <path android:fillColor="#1A1400"
        android:pathData="M48,43 Q48,40,54,40 Q60,40,60,44 Q60,47,54,48 Q47,49,47,53 Q47,57,54,57 Q61,57,61,54"
        android:strokeColor="#1A1400"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillAlpha="0" />

    <!-- S lettermark strokes — top bar -->
    <path android:fillColor="#1A1400"
        android:pathData="M48.5,42 L59.5,42"
        android:strokeColor="#0A0C12"
        android:strokeWidth="2.8"
        android:strokeLineCap="round" />
    <!-- S mid bar -->
    <path android:fillColor="#1A1400"
        android:pathData="M48,48 L60,48"
        android:strokeColor="#0A0C12"
        android:strokeWidth="2.8"
        android:strokeLineCap="round" />
    <!-- S bottom bar -->
    <path android:fillColor="#1A1400"
        android:pathData="M48.5,54 L59.5,54"
        android:strokeColor="#0A0C12"
        android:strokeWidth="2.8"
        android:strokeLineCap="round" />

</vector>
