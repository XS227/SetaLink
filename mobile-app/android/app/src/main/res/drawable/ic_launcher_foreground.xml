<?xml version="1.0" encoding="utf-8"?>
<!--
  SetaLink launcher foreground — emerald diamond centered in 108dp adaptive icon canvas.
  The 72dp "safe zone" is offset 18dp from each edge, so the diamond sits within it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Diamond: center=54,54  half-size=27dp (fills safe zone comfortably) -->
    <path
        android:fillColor="#00E87A"
        android:pathData="M54,27 L81,54 L54,81 L27,54 Z" />

</vector>
