import json, re, os
from collections import Counter
from datetime import datetime, timezone, timedelta

ACCESS_LOG = "/var/log/xray/access.log"
ERROR_LOG  = "/var/log/xray/error.log"

result = {
    "total_events": 0,
    "user_connections": 0,
    "internal_api_polls": 0,
    "unique_client_ips": 0,
    "unique_ip_list": [],
    "last_user_conn_at": None,
    "recent_errors": [],
    "error_count": 0,
    "warning_count": 0,
    "xray_restarts": 0,
    "destinations": [],
    "access_log_lines": 0,
}

ip_set = set()
dest_counter = Counter()
last_conn = None

if os.path.exists(ACCESS_LOG):
    try:
        with open(ACCESS_LOG, "r", errors="replace") as f:
            lines = f.readlines()
        result["access_log_lines"] = len(lines)
        for line in lines:
            line = line.strip()
            if not line:
                continue
            if "[Warning]" in line and "started" in line:
                result["xray_restarts"] += 1
                continue
            if "[Warning]" in line or "[Error]" in line or "[Debug]" in line or "[Info]" in line:
                continue
            result["total_events"] += 1
            if "[api -> api]" in line:
                result["internal_api_polls"] += 1
                continue
            result["user_connections"] += 1
            m_ip = re.search(r"from (\d+\.\d+\.\d+\.\d+):", line)
            if m_ip:
                ip_set.add(m_ip.group(1))
            m_dest = re.search(r"accepted \w+:([^\s]+)", line)
            if m_dest:
                dest_counter[m_dest.group(1)] += 1
            m_ts = re.match(r"(\d{4}/\d{2}/\d{2} \d{2}:\d{2}:\d{2})", line)
            if m_ts:
                last_conn = m_ts.group(1)
    except Exception as e:
        result["access_log_error"] = str(e)

result["unique_client_ips"] = len(ip_set)
result["unique_ip_list"] = sorted(ip_set)[:20]
result["last_user_conn_at"] = last_conn
result["destinations"] = [{"dest": d, "count": c} for d, c in dest_counter.most_common(10)]

if os.path.exists(ERROR_LOG):
    try:
        with open(ERROR_LOG, "r", errors="replace") as f:
            err_lines = f.readlines()
        result["error_count"]   = sum(1 for l in err_lines if "[Error]" in l)
        result["warning_count"] = sum(1 for l in err_lines if "[Warning]" in l)
        recent = []
        for line in reversed(err_lines[-300:]):
            line = line.strip()
            if not line:
                continue
            if "[Error]" in line or "[Warning]" in line:
                recent.append(line[-400:])
                if len(recent) >= 25:
                    break
        result["recent_errors"] = list(reversed(recent))
    except Exception as e:
        result["error_log_error"] = str(e)

print(json.dumps(result))
