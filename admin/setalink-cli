import json, time, subprocess, sys
def read_cpu():
    with open('/proc/stat') as f:
        p = f.readline().split()
    v = list(map(int, p[1:]))
    return sum(v), v[3]
t1,i1 = read_cpu(); time.sleep(0.3); t2,i2 = read_cpu()
dt,di = t2-t1, i2-i1
cpu = round((1-di/dt)*100,1) if dt>0 else 0
mem={}
with open('/proc/meminfo') as f:
    for line in f:
        k,v = line.split(':')
        mem[k.strip()] = int(v.split()[0])
mt,ma = mem.get('MemTotal',0), mem.get('MemAvailable',0)
mu = mt-ma
with open('/proc/uptime') as f: up=int(float(f.read().split()[0]))
with open('/proc/loadavg') as f: ld=f.read().split()
try:
    df=subprocess.check_output(['df','-B1','/'],stderr=subprocess.DEVNULL).decode().split('\n')[1].split()
    dt_b,du_b = int(df[1]),int(df[2])
except Exception: dt_b,du_b=0,0
print(json.dumps({
    'cpu_pct':cpu,
    'mem_total_kb':mt,'mem_used_kb':mu,
    'mem_pct':round(mu/mt*100,1) if mt else 0,
    'uptime_sec':up,
    'load1':float(ld[0]),'load5':float(ld[1]),'load15':float(ld[2]),
    'disk_total':dt_b,'disk_used':du_b,
    'disk_pct':round(du_b/dt_b*100,1) if dt_b else 0,
}))
