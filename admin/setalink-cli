#!/usr/bin/env bash
# SetaLink admin CLI — the SOLE program in the sudoers whitelist for www-data.
# Every state-changing or privileged action the PHP dashboard performs must
# go through this wrapper. Subcommands re-validate every argument so that PHP
# (or anything that compromises PHP) cannot inject shell metacharacters or
# escalate beyond the closed set defined here.
#
# Owned root:root, mode 0755 — www-data must NOT be able to modify this file.
# If www-data could write here, the sudoers entry would be a privilege
# escalation. Permissions are enforced by setup-admin.sh.

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
# shellcheck disable=SC1091
. "$REPO_DIR/lib.sh"

require_root "$@"   # Always invoked via sudo — bail out otherwise.

ACTION="${1:-}"
[ -n "$ACTION" ] || { echo "usage: setalink-cli <action> [args]" >&2; exit 2; }
shift

# Strict username validation, identical regex to lib.sh::validate_username.
# We re-validate inside the wrapper rather than trusting the caller.
_check_name() {
    local n="${1:-}"
    [ -n "$n" ] || { echo "missing username" >&2; exit 2; }
    [[ "$n" =~ ^[a-z0-9][a-z0-9._-]{0,31}$ ]] || \
        { echo "invalid username" >&2; exit 2; }
}

# Format bytes as human-readable string (e.g. 2.3GB, 500MB).
_fmt_bytes() {
    awk -v b="$1" 'BEGIN{
        if      (b>=1073741824) printf "%.1fGB", b/1073741824
        else if (b>=1048576)    printf "%.1fMB", b/1048576
        else if (b>=1024)       printf "%.1fKB", b/1024
        else                    printf "%dB",    b
    }'
}

# Generate a full Xray client JSON config and write to
# $SETALINK_USERS_DIR/<name>/full.json (mode 0600).
# Args: <name> <uuid> <shortId>
_gen_full_json() {
    local _name="$1" _uuid="$2" _sid="$3"
    # shellcheck disable=SC1090
    . "$SETALINK_ENV"
    local _dir="$SETALINK_USERS_DIR/$_name"
    local _port="${SETALINK_REALITY_PORT:-8443}"

    local _used _quota _used_fmt _quota_fmt _remarks
    _used="$(jq -r --arg n "$_name" '.users[] | select(.name == $n) | (.used_bytes  // 0)' "$SETALINK_USERS_DB")"
    _quota="$(jq -r --arg n "$_name" '.users[] | select(.name == $n) | (.quota_bytes // 0)' "$SETALINK_USERS_DB")"
    _used_fmt="$(_fmt_bytes "${_used:-0}")"
    _quota_fmt="$([ "${_quota:-0}" = "0" ] && echo "∞" || _fmt_bytes "$_quota")"
    _remarks="📊 $_name - $_used_fmt/$_quota_fmt"

    mkdir -p "$_dir"
    chmod 0700 "$_dir"
    jq -n \
        --arg host    "$SETALINK_HOST" \
        --arg port    "$_port" \
        --arg sni     "${SETALINK_REALITY_SNI:-www.microsoft.com}" \
        --arg pubkey  "${SETALINK_REALITY_PUBLIC_KEY:-$SETALINK_PUBLIC_KEY}" \
        --arg uuid    "$_uuid" \
        --arg sid     "$_sid" \
        --arg remarks "$_remarks" \
        '{
          remarks: $remarks,
          log: { loglevel: "warning" },
          dns: {
            servers: ["1.1.1.1", "8.8.8.8"]
          },
          fakedns: [
            { ipPool: "198.20.0.0/15", poolSize: 128 },
            { ipPool: "fc00::/64",     poolSize: 128  }
          ],
          inbounds: [{
            listen:   "127.0.0.1",
            port:     1080,
            protocol: "socks",
            tag:      "socks",
            settings: { auth: "noauth", udp: true },
            sniffing: {
              enabled:     true,
              destOverride: ["http","tls","quic"],
              routeOnly:   true
            }
          }],
          outbounds: [
            {
              tag:      "proxy",
              protocol: "vless",
              settings: {
                vnext: [{
                  address: $host,
                  port:    ($port | tonumber),
                  users: [{
                    id:         $uuid,
                    flow:       "xtls-rprx-vision",
                    encryption: "none"
                  }]
                }]
              },
              streamSettings: {
                network:  "tcp",
                security: "reality",
                realitySettings: {
                  show:        false,
                  fingerprint: "chrome",
                  serverName:  $sni,
                  publicKey:   $pubkey,
                  shortId:     $sid,
                  spiderX:     "/"
                }
              }
            },
            { tag: "DIRECT", protocol: "freedom"   },
            { tag: "BLOCK",  protocol: "blackhole"  },
            { tag: "direct", protocol: "freedom"    },
            { tag: "block",  protocol: "blackhole"  }
          ],
          routing: {
            domainStrategy: "AsIs",
            rules: []
          }
        }' > "$_dir/full.json.new"
    install -m 0600 -o root -g root "$_dir/full.json.new" "$_dir/full.json"
    rm -f "$_dir/full.json.new"
}

case "$ACTION" in
    status)
        # Server-status JSON. Read-only; no setuid scripts called.
        # shellcheck disable=SC1090
        . "$SETALINK_ENV"
        XRAY_STATE=$(systemctl is-active xray  2>/dev/null || true)
        NGINX_STATE=$(systemctl is-active nginx 2>/dev/null || true)
        UFW_STATE=$(ufw status 2>/dev/null | awk '/^Status:/{print $2; exit}')
        TOTAL=$(jq '.users | length' "$SETALINK_USERS_DB" 2>/dev/null || echo 0)
        DISABLED=$(jq '[.users[] | select((.disabled // false) == true)] | length' \
                    "$SETALINK_USERS_DB" 2>/dev/null || echo 0)
        ACTIVE=$(( TOTAL - DISABLED ))
        # Reality + transport config
        R_PORT="${SETALINK_REALITY_PORT:-8443}"
        R_SNI="${SETALINK_REALITY_SNI:-www.microsoft.com}"
        R_SID="${SETALINK_REALITY_SHORT_ID_SERVER:-}"
        R_SID_PREFIX="${R_SID:0:6}"
        R_FLOW="${SETALINK_REALITY_FLOW:-xtls-rprx-vision}"
        R_FP="${SETALINK_REALITY_FINGERPRINT:-chrome}"
        R_PUBKEY="${SETALINK_REALITY_PUBLIC_KEY:-${SETALINK_PUBLIC_KEY:-}}"
        E_HOST="${SETALINK_EDGE_HOST:-$SETALINK_HOST}"
        E_PORT="${SETALINK_NGINX_PORT:-443}"
        WS_PATH_VAL="${SETALINK_WS_PATH:-/ws}"
        XHTTP_PATH_VAL="${SETALINK_XHTTP_PATH:-/xhttp}"
        HTTPUP_PATH_VAL="${SETALINK_HTTPUP_PATH:-/httpup}"
        jq -n \
            --arg xray "$XRAY_STATE" \
            --arg nginx "$NGINX_STATE" \
            --arg ufw "$UFW_STATE" \
            --argjson total "$TOTAL" \
            --argjson active "$ACTIVE" \
            --argjson disabled "$DISABLED" \
            --argjson max "$MAX_USERS" \
            --arg client_port "${SETALINK_CLIENT_PORT:-$SETALINK_PORT}" \
            --arg listen_port "$SETALINK_PORT" \
            --arg sni "$SETALINK_SNI" \
            --arg host "$SETALINK_HOST" \
            --arg r_port "$R_PORT" \
            --arg r_sni "$R_SNI" \
            --arg r_sid_prefix "$R_SID_PREFIX" \
            --arg r_flow "$R_FLOW" \
            --arg r_fp "$R_FP" \
            --arg r_pubkey "$R_PUBKEY" \
            --arg e_host "$E_HOST" \
            --arg e_port "$E_PORT" \
            --arg ws_path "$WS_PATH_VAL" \
            --arg xhttp_path "$XHTTP_PATH_VAL" \
            --arg httpup_path "$HTTPUP_PATH_VAL" \
            '{
                services: { xray: $xray, nginx: $nginx, ufw: $ufw },
                ports:    { public: ($client_port|tonumber),
                            xray_internal: ($listen_port|tonumber) },
                sni:      $sni,
                host:     $host,
                users:    { total: $total, active: $active,
                            disabled: $disabled, max: $max },
                reality: {
                    host:        $host,
                    port:        ($r_port|tonumber),
                    sni:         $r_sni,
                    shortId:     $r_sid_prefix,
                    flow:        $r_flow,
                    fingerprint: $r_fp,
                    publicKey:   $r_pubkey
                },
                transports: {
                    edge_host: $e_host,
                    edge_port: ($e_port|tonumber),
                    ws:        { path: $ws_path },
                    xhttp:     { path: $xhttp_path },
                    httpup:    { path: $httpup_path }
                }
            }'
        ;;

    list)
        # users.json + computed totals + per-user fields including expiry.
        jq --arg dir "$SETALINK_USERS_DIR" --argjson max "$MAX_USERS" \
           --arg now "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '
            {
                max: $max,
                total: (.users | length),
                active: ([.users[] | select((.disabled // false) != true)] | length),
                disabled: ([.users[] | select((.disabled // false) == true)] | length),
                users: (.users | map({
                    name:            .name,
                    uuid:            .uuid,
                    shortId:         .shortId,
                    created:         .created,
                    disabled:        ((.disabled // false) == true),
                    disabled_reason: (.disabled_reason // null),
                    package_name:    (.package_name // "unlimited"),
                    quota_bytes:     (.quota_bytes  // 0),
                    used_bytes:      (.used_bytes     // 0),
                    upload_bytes:    (.upload_bytes   // 0),
                    download_bytes:  (.download_bytes // 0),
                    last_seen_at:    (.last_seen_at // null),
                    expires_at:      (.expires_at   // null),
                    is_expired:      ((.expires_at != null) and (.expires_at <= $now)),
                    remaining_bytes: (
                        if ((.quota_bytes // 0) > 0)
                        then (((.quota_bytes // 0) - (.used_bytes // 0)) | (if . < 0 then 0 else . end))
                        else null end
                    ),
                    usage_percent: (
                        if ((.quota_bytes // 0) > 0)
                        then ((((.used_bytes // 0) / (.quota_bytes // 0)) * 100) | floor)
                        else null end
                    )
                }))
            }
        ' "$SETALINK_USERS_DB"
        ;;

    add)
        _check_name "${1:-}"
        ADD_PKG="${2:-unlimited}"
        case "$ADD_PKG" in
            7days|30days|unlimited|5GB|10GB|15GB) ;;
            *) echo "invalid package: $ADD_PKG" >&2; exit 2 ;;
        esac
        "$REPO_DIR/add-user.sh" "$1" --package="$ADD_PKG"
        # Generate full client JSON for the newly created user.
        _add_uuid="$(jq -r --arg n "$1" '.users[] | select(.name == $n) | .uuid'    "$SETALINK_USERS_DB")"
        _add_sid="$( jq -r --arg n "$1" '.users[] | select(.name == $n) | .shortId' "$SETALINK_USERS_DB")"
        _gen_full_json "$1" "$_add_uuid" "$_add_sid"
        ;;

    remove|delete)
        _check_name "${1:-}"
        "$REPO_DIR/remove-user.sh" "$1"
        ;;

    disable)
        _check_name "${1:-}"
        "$REPO_DIR/disable-user.sh" "$1"
        ;;

    enable)
        _check_name "${1:-}"
        "$REPO_DIR/enable-user.sh" "$1"
        ;;

    reset-traffic)
        # Clear used_bytes for one user. Metadata-only — no xray restart.
        # Note: any traffic accumulated in xray's stats counter since the last
        # poll-traffic.sh run will still be added on the next poll. To zero
        # both simultaneously, run poll-traffic.sh immediately after.
        _check_name "${1:-}"
        if ! jq -e --arg n "$1" '.users[] | select(.name == $n)' "$SETALINK_USERS_DB" >/dev/null; then
            echo "user '$1' not found" >&2; exit 3
        fi
        TMP="$(mktemp /tmp/setalink-users.XXXXXX.json)"
        jq --arg n "$1" '.users |= map(if .name == $n then .used_bytes = 0 else . end)' \
            "$SETALINK_USERS_DB" > "$TMP"
        install -m 0600 -o root -g root "$TMP" "$SETALINK_USERS_DB"
        rm -f "$TMP"
        ok "reset traffic for '$1'"
        ;;

    change-package)
        # Update a user's package_name + quota_bytes. Does NOT auto-enable a
        # user who was previously auto-disabled — admin must enable explicitly.
        _check_name "${1:-}"
        CP_PKG="${2:-}"
        validate_package_name "$CP_PKG"
        CP_QUOTA="$(package_to_bytes "$CP_PKG")"
        if ! jq -e --arg n "$1" '.users[] | select(.name == $n)' "$SETALINK_USERS_DB" >/dev/null; then
            echo "user '$1' not found" >&2; exit 3
        fi
        TMP="$(mktemp /tmp/setalink-users.XXXXXX.json)"
        jq --arg n "$1" --arg p "$CP_PKG" --argjson q "$CP_QUOTA" \
            '.users |= map(if .name == $n then .package_name = $p | .quota_bytes = $q else . end)' \
            "$SETALINK_USERS_DB" > "$TMP"
        install -m 0600 -o root -g root "$TMP" "$SETALINK_USERS_DB"
        rm -f "$TMP"
        ok "set package for '$1' to '$CP_PKG' (quota=$CP_QUOTA)"
        ;;

    regen-link)
        # Rebuild link.txt + qr.png from the user's current uuid/shortId.
        # Useful if the per-user files were lost or the env-derived URL changed
        # (e.g. SETALINK_CLIENT_PORT was updated). No xray restart needed.
        _check_name "${1:-}"
        require_cmd qrencode
        RL_UUID="$(jq -r --arg n "$1" '.users[] | select(.name == $n) | .uuid'    "$SETALINK_USERS_DB")"
        RL_SID="$( jq -r --arg n "$1" '.users[] | select(.name == $n) | .shortId' "$SETALINK_USERS_DB")"
        [ -n "$RL_UUID" ] && [ "$RL_UUID" != "null" ] || { echo "user '$1' not found" >&2; exit 3; }
        RL_DIR="$SETALINK_USERS_DIR/$1"
        mkdir -p "$RL_DIR"
        chmod 0700 "$RL_DIR"
        RL_URL="$(build_vless_url "$RL_UUID" "$RL_SID" "$1")"
        umask 077
        printf '%s\n' "$RL_URL" > "$RL_DIR/link.txt.new"
        mv "$RL_DIR/link.txt.new" "$RL_DIR/link.txt"
        qrencode -o "$RL_DIR/qr.png.new" -t PNG -s 8 -m 2 "$RL_URL"
        mv "$RL_DIR/qr.png.new" "$RL_DIR/qr.png"
        chown root:root "$RL_DIR/link.txt" "$RL_DIR/qr.png"
        chmod 0600       "$RL_DIR/link.txt" "$RL_DIR/qr.png"
        umask 022
        ok "regenerated link + qr for '$1'"
        _gen_full_json "$1" "$RL_UUID" "$RL_SID"
        ;;

    gen-full-json)
        _check_name "${1:-}"
        GFJ_UUID="$(jq -r --arg n "$1" '.users[] | select(.name == $n) | .uuid'    "$SETALINK_USERS_DB")"
        GFJ_SID="$( jq -r --arg n "$1" '.users[] | select(.name == $n) | .shortId' "$SETALINK_USERS_DB")"
        [ -n "$GFJ_UUID" ] && [ "$GFJ_UUID" != "null" ] || { echo "user '$1' not found" >&2; exit 3; }
        _gen_full_json "$1" "$GFJ_UUID" "$GFJ_SID"
        ok "generated full.json for '$1'"
        ;;

    read-full-json)
        _check_name "${1:-}"
        F="$SETALINK_USERS_DIR/$1/full.json"
        [ -r "$F" ] || { echo "no full.json for user '$1'" >&2; exit 3; }
        cat "$F"
        ;;

    verify-links)
        # Parse and validate a user's Reality link + full.json against server config.
        # Usage: setalink-cli verify-links <username>
        _check_name "${1:-}"
        # shellcheck disable=SC1090
        . "$SETALINK_ENV"
        VL_USER="$1"
        VL_LINK="$SETALINK_USERS_DIR/$VL_USER/link.txt"
        VL_JSON="$SETALINK_USERS_DIR/$VL_USER/full.json"

        E_PORT="${SETALINK_REALITY_PORT:-8443}"
        E_SNI="${SETALINK_REALITY_SNI:-www.microsoft.com}"
        E_PBK="${SETALINK_REALITY_PUBLIC_KEY:-$SETALINK_PUBLIC_KEY}"
        E_FLOW="xtls-rprx-vision"
        E_FP="chrome"

        PASS=0; FAIL=0

        _check() {
            local label="$1" got="$2" expected="$3"
            if [ "$got" = "$expected" ]; then
                echo "  ✓ $label: $got"
                PASS=$((PASS+1))
            else
                echo "  ✗ $label: got='$got' expected='$expected'"
                FAIL=$((FAIL+1))
            fi
        }

        echo ""
        echo "── link.txt ──────────────────────────────"
        if [ -r "$VL_LINK" ]; then
            L="$(cat "$VL_LINK")"
            # Parse params from vless URL
            _port="$(printf '%s' "$L" | grep -oP '(?<=:)\d+(?=\?)' || echo '')"
            _sni="$(printf '%s' "$L" | grep -oP '(?<=sni=)[^&]+' || echo '')"
            _pbk="$(printf '%s' "$L" | grep -oP '(?<=pbk=)[^&]+' || echo '')"
            _flow="$(printf '%s' "$L" | grep -oP '(?<=flow=)[^&]+' || echo '')"
            _fp="$(printf '%s' "$L" | grep -oP '(?<=fp=)[^&]+' || echo '')"
            _check "port" "$_port" "$E_PORT"
            _check "sni " "$_sni"  "$E_SNI"
            _check "pbk " "$_pbk"  "$E_PBK"
            _check "flow" "$_flow" "$E_FLOW"
            _check "fp  " "$_fp"   "$E_FP"
        else
            echo "  ✗ link.txt not found"
            FAIL=$((FAIL+1))
        fi

        echo ""
        echo "── full.json ─────────────────────────────"
        if [ -r "$VL_JSON" ]; then
            _port="$(jq -r '.outbounds[0].settings.vnext[0].port' "$VL_JSON")"
            _sni="$(jq -r '.outbounds[0].streamSettings.realitySettings.serverName' "$VL_JSON")"
            _pbk="$(jq -r '.outbounds[0].streamSettings.realitySettings.publicKey' "$VL_JSON")"
            _flow="$(jq -r '.outbounds[0].settings.vnext[0].users[0].flow' "$VL_JSON")"
            _fp="$(jq -r '.outbounds[0].streamSettings.realitySettings.fingerprint' "$VL_JSON")"
            _check "port" "$_port" "$E_PORT"
            _check "sni " "$_sni"  "$E_SNI"
            _check "pbk " "$_pbk"  "$E_PBK"
            _check "flow" "$_flow" "$E_FLOW"
            _check "fp  " "$_fp"   "$E_FP"
        else
            echo "  ✗ full.json not found"
            FAIL=$((FAIL+1))
        fi

        echo ""
        if [ "$FAIL" -eq 0 ]; then
            echo "  Result: $PASS/$((PASS+FAIL)) checks passed — all params correct ✓"
        else
            echo "  Result: $FAIL check(s) FAILED — regenerate with: setalink-cli regen-link $VL_USER"
            exit 1
        fi
        ;;

    read-link)
        _check_name "${1:-}"
        # shellcheck disable=SC1090
        . "$SETALINK_ENV"
        F="$SETALINK_USERS_DIR/$1/link.txt"
        [ -r "$F" ] || { echo "no link for user '$1'" >&2; exit 3; }
        cat "$F"
        ;;

    read-qr)
        _check_name "${1:-}"
        # shellcheck disable=SC1090
        . "$SETALINK_ENV"
        F="$SETALINK_USERS_DIR/$1/qr.png"
        [ -r "$F" ] || { echo "no qr for user '$1'" >&2; exit 3; }
        cat "$F"
        ;;

    regen-all-full-json)
        # Regenerate full.json for every user in users.json.
        mapfile -t _all_names < <(jq -r '.users[].name' "$SETALINK_USERS_DB")
        for _u in "${_all_names[@]}"; do
            _u_uuid="$(jq -r --arg n "$_u" '.users[] | select(.name == $n) | .uuid'    "$SETALINK_USERS_DB")"
            _u_sid="$( jq -r --arg n "$_u" '.users[] | select(.name == $n) | .shortId' "$SETALINK_USERS_DB")"
            _gen_full_json "$_u" "$_u_uuid" "$_u_sid"
            ok "regenerated full.json for '$_u'"
        done
        ok "done — regenerated full.json for ${#_all_names[@]} user(s)"
        ;;

    gen-links)
        # Return JSON with all 5 transport VLESS links for a user.
        _check_name "${1:-}"
        # shellcheck disable=SC1090
        . "$SETALINK_ENV"
        GL_UUID="$(jq -r --arg n "$1" '.users[] | select(.name==$n) | .uuid'    "$SETALINK_USERS_DB")"
        GL_SID="$( jq -r --arg n "$1" '.users[] | select(.name==$n) | .shortId' "$SETALINK_USERS_DB")"
        [ -n "$GL_UUID" ] && [ "$GL_UUID" != "null" ] || { echo "user '$1' not found" >&2; exit 3; }
        GL_HOST="${SETALINK_EDGE_HOST:-$SETALINK_HOST}"
        GL_NPORT="${SETALINK_NGINX_PORT:-443}"
        GL_WS="${SETALINK_WS_PATH:-/ws}"
        GL_XHTTP="${SETALINK_XHTTP_PATH:-/xhttp}"
        GL_HTTPUP="${SETALINK_HTTPUP_PATH:-/httpup}"
        GL_RPORT="${SETALINK_REALITY_PORT:-8443}"
        GL_RSNI="${SETALINK_REALITY_SNI:-www.microsoft.com}"
        GL_RPBK="${SETALINK_REALITY_PUBLIC_KEY:-$SETALINK_PUBLIC_KEY}"
        GL_NENC="$(printf '%s' "$1" | jq -sRr @uri)"
        jq -n \
            --arg user  "$1"         --arg uuid "$GL_UUID"  --arg sid  "$GL_SID" \
            --arg host  "$GL_HOST"   --arg np   "$GL_NPORT" \
            --arg ws    "$GL_WS"     --arg xh   "$GL_XHTTP" --arg hu   "$GL_HTTPUP" \
            --arg rp    "$GL_RPORT"  --arg rsni "$GL_RSNI"  --arg rpbk "$GL_RPBK" \
            --arg nenc  "$GL_NENC" \
            '{
              user: $user, uuid: $uuid,
              links: {
                ws:      ("vless://"+$uuid+"@"+$host+":"+$np+"?security=tls&type=ws&path="+($ws|@uri)+"&host="+$host+"&sni="+$host+"#"+$nenc+"-WS"),
                chrome:  ("vless://"+$uuid+"@"+$host+":"+$np+"?security=tls&type=ws&path="+($ws|@uri)+"&host="+$host+"&sni="+$host+"&fp=chrome&alpn=http%2F1.1#"+$nenc+"-CHROME"),
                xhttp:   ("vless://"+$uuid+"@"+$host+":"+$np+"?security=tls&type=xhttp&path="+($xh|@uri)+"&host="+$host+"&sni="+$host+"&fp=chrome#"+$nenc+"-XHTTP"),
                httpup:  ("vless://"+$uuid+"@"+$host+":"+$np+"?security=tls&type=httpupgrade&path="+($hu|@uri)+"&host="+$host+"&sni="+$host+"&alpn=http%2F1.1#"+$nenc+"-HTTPUP"),
                reality: ("vless://"+$uuid+"@"+$host+":"+$rp+"?security=reality&type=tcp&flow=xtls-rprx-vision&sni="+$rsni+"&fp=chrome&pbk="+$rpbk+"&sid="+$sid+"&spx=%2F#"+$nenc+"-REALITY")
              }
            }'
        ;;

    gen-qr-transport)
        # Generate QR PNG for one transport. Args: <name> <transport>
        _check_name "${1:-}"
        GQT_T="${2:-ws}"
        case "$GQT_T" in ws|chrome|xhttp|httpup|reality) ;;
            *) echo "invalid transport" >&2; exit 2 ;; esac
        require_cmd qrencode
        # shellcheck disable=SC1090
        . "$SETALINK_ENV"
        GQT_UUID="$(jq -r --arg n "$1" '.users[] | select(.name==$n) | .uuid'    "$SETALINK_USERS_DB")"
        GQT_SID="$( jq -r --arg n "$1" '.users[] | select(.name==$n) | .shortId' "$SETALINK_USERS_DB")"
        [ -n "$GQT_UUID" ] && [ "$GQT_UUID" != "null" ] || { echo "user '$1' not found" >&2; exit 3; }
        GQT_H="${SETALINK_EDGE_HOST:-$SETALINK_HOST}"
        GQT_NP="${SETALINK_NGINX_PORT:-443}"
        GQT_WS="${SETALINK_WS_PATH:-/ws}"
        GQT_XH="${SETALINK_XHTTP_PATH:-/xhttp}"
        GQT_HU="${SETALINK_HTTPUP_PATH:-/httpup}"
        GQT_RP="${SETALINK_REALITY_PORT:-8443}"
        GQT_RS="${SETALINK_REALITY_SNI:-www.microsoft.com}"
        GQT_RK="${SETALINK_REALITY_PUBLIC_KEY:-$SETALINK_PUBLIC_KEY}"
